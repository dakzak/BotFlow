# Copier ce fichier en `.env` pour le développement local : copy .env.example .env
# puis appliquer le schéma : npx prisma migrate dev

# Port d'écoute du serveur Express
PORT=3000

# Clé de signature des jetons JWT — OBLIGATOIRE en production (longue chaîne aléatoire)
JWT_SECRET=change-me-en-production

# Base SQLite via Prisma. Le chemin relatif est résolu depuis le dossier prisma/.
# Local  : file:../data/botflow.db  ->  ./data/botflow.db à la racine du projet
# Railway: file:/data/botflow.db    (volume persistant monté sur /data)
DATABASE_URL="file:../data/botflow.db"

# Dossier racine des sessions WhatsApp par agent (sur Railway : /data/sessions)
SESSIONS_DIR=./sessions

# Les clés d'API IA (Groq / Gemini) ne vont PAS ici :
# elles sont fournies par chaque organisation et stockées par agent en base.
